{
  "name": "@drizzle-pulse/client",
  "version": "0.0.1",
  "description": "Type-safe realtime client SDK for drizzle-pulse with drizzle-style API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./embedded": {
      "types": "./dist/embedded/index.d.ts",
      "import": "./dist/embedded/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit && tsc --noEmit --project src/__tests__/tsconfig.json",
    "test": "bun test",
    "test:types": "tsc --noEmit --project type-tests/tsconfig.json"
  },
  "peerDependencies": {
    "drizzle-orm": "*",
    "react": ">=18.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "hono": "^4.6.0",
    "pg": "^8.13.0",
    "pg-logical-replication": "^2.1.0",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "bun-types": "^1.3.8",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.2.0",
    "drizzle-orm": "^1.0.0-rc.4",
    "fast-check": "^3.23.2",
    "react": "^18.2.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
