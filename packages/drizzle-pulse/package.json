{
  "name": "drizzle-pulse",
  "version": "0.0.4",
  "description": "Type-safe realtime SDK for Drizzle — server runtime, HTTP client, React hook, and embedded client",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Dan Kochetov",
  "homepage": "https://github.com/drizzle-team/drizzle-pulse#readme",
  "bugs": "https://github.com/drizzle-team/drizzle-pulse/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drizzle-team/drizzle-pulse.git"
  },
  "keywords": [
    "drizzle",
    "drizzle-orm",
    "postgres",
    "postgresql",
    "realtime",
    "wal",
    "logical-replication",
    "live-query",
    "typescript",
    "esm"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": [
    "./dist/shared/superjson.js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./client/react": {
      "types": "./dist/client/react/index.d.ts",
      "default": "./dist/client/react/index.js"
    },
    "./client/embedded": {
      "types": "./dist/client/embedded/index.d.ts",
      "default": "./dist/client/embedded/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "tsc",
    "typecheck": "tsc --noEmit && tsc --noEmit --project src/__tests__/tsconfig.json",
    "test": "bun test",
    "test:types": "tsc --noEmit --project type-tests/tsconfig.json",
    "lint:publish": "publint --strict",
    "check:types": "attw --pack --profile esm-only",
    "verify:publish": "bun run lint:publish && bun run check:types && node ../../scripts/pack-check.mjs"
  },
  "peerDependencies": {
    "drizzle-orm": "^1.0.0-rc.4",
    "react": ">=18.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@types/pg": "^8.11.0",
    "pg": "^8.13.0",
    "pg-logical-replication": "^2.1.0",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.0",
    "bun-types": "^1.3.8",
    "drizzle-orm": "^1.0.0-rc.4",
    "fast-check": "^3.23.2",
    "hono": "^4.6.0",
    "publint": "^0.3.21",
    "react": "^18.2.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
